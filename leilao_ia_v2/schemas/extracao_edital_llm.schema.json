{
  "$defs": {
    "LeilaoExtraJson": {
      "description": "Conteúdo gravado em `leilao_imoveis.leilao_extra_json`.\nTextos longos em markdown onde fizer sentido para o próximo agente.",
      "properties": {
        "formas_pagamento": {
          "items": {
            "type": "string"
          },
          "title": "Formas Pagamento",
          "type": "array"
        },
        "processo_judicial": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProcessoJudicial"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "regras_leilao_markdown": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Regras Leilao Markdown"
        },
        "observacoes_markdown": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observacoes Markdown"
        },
        "tipo_pagamento_resumo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tipo Pagamento Resumo"
        },
        "modalidade_venda": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "leilao = há datas de 1ª e/ou 2ª praça ou leilão explícito; venda_direta = oferta sem 1ª/2ª praça (ex.: 'venda direta', 'Tipo de Venda: vendadireta') ou quando não houver data_leilao_1_praca nem data_leilao_2_praca e o anúncio for compra direta",
          "title": "Modalidade Venda"
        }
      },
      "title": "LeilaoExtraJson",
      "type": "object"
    },
    "ProcessoJudicial": {
      "description": "Processo judicial relacionado ao leilão (dados públicos do edital).",
      "properties": {
        "numero": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Numero"
        },
        "vara": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vara"
        },
        "comarca": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Comarca"
        }
      },
      "title": "ProcessoJudicial",
      "type": "object"
    }
  },
  "description": "Resposta esperada do modelo após ler o markdown do Firecrawl.",
